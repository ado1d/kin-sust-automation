# Supabase PostgreSQL Connection
# ============================================
# For LOCAL DEVELOPMENT (connection pooler):
DATABASE_URL=postgresql://postgres.xxxxxx:[YOUR-PASSWORD]@aws-1-ap-northeast-1.pooler.supabase.com:5432/postgres

# For MIGRATIONS (direct connection — no pooler):
# Find this in Supabase Dashboard → Settings → Database → Connection string → URI

NEXT_PUBLIC_APP_URL=http://localhost:3000
